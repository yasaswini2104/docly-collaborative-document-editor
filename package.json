{
  "name": "doceditor",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/client\" \"npm run dev -w apps/server\"",
    "build": "npm run build -w apps/client && npm run build -w apps/server",
    "test": "npm run test -w apps/client && npm run test -w apps/server",
    "test:client": "npm run test -w apps/client",
    "test:server": "npm run test -w apps/server",
    "lint": "eslint \"apps/**/*.{ts,tsx}\"",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.30.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true,
    "esbuild@0.28.1": true,
    "bcrypt@5.1.1": true
  }
}
